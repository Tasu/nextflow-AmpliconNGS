/*
 * nextflow.config
 */

def default_container_images = [
    porechop   : 'https://depot.galaxyproject.org/singularity/porechop:0.2.4--py39h2de1943_9',
    seqkit     : 'https://depot.galaxyproject.org/singularity/seqkit:2.9.0--h9ee0642_0',
    cutadapt   : 'https://depot.galaxyproject.org/singularity/cutadapt:5.0--py39hbcbf7aa_0',
    biopython  : 'https://depot.galaxyproject.org/singularity/biopython:1.79',
    kraken2    : 'https://depot.galaxyproject.org/singularity/kraken2:2.1.3--pl5321h077b44d_4',
    krakentools: 'docker://nanozoo/krakentools:1.2--13d5ba5',
    blast      : 'https://depot.galaxyproject.org/singularity/blast:2.16.0--h66d330f_4',
    taxonkit   : 'https://depot.galaxyproject.org/singularity/taxonkit:0.18.0--h9ee0642_0',
    biom_format: 'https://depot.galaxyproject.org/singularity/biom-format:2.1.15'
]

// 1. Default Parameters (overridden by -params-file)
params {
    sample_sheet = "sampleSheet.csv"
    outdir       = "results"

    // Central container image catalog (single source of truth)
    // Users can set full or partial overrides via params.container_images.
    container_images = [:]

    // Container preflight checks (non-breaking by default)
    container_preflight_check         = true
    container_preflight_strict        = false
    container_preflight_timeout_ms    = 8000
    container_preflight_suggest_tags  = true
    container_preflight_check_docker  = true
    container_registry_index_url      = 'https://depot.galaxyproject.org/singularity/'
    container_suggestion_limit        = 5
    preflight_only                    = false
    
    // Resource defaults (fallback)
    max_cpus     = 8
    max_memory   = '32.GB'
    max_time     = '24.h'
}

// Merge order:
// 1) default_container_images
// 2) params.container_images (full or partial override)
params.container_images =
    default_container_images +
    ((params.container_images ?: [:]) as Map)

// 2. Resource Management Logic
// This function ensures the process doesn't request more than the defined max_resource
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            return obj
        }
    }
}

// 3. Process Resource Allocation
process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'terminate' }
    maxRetries    = 2

    withLabel: 'process_low' {
        cpus   = { check_max( 1 * task.attempt, 'cpus' ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
    }
    withLabel: 'process_medium' {
        cpus   = { check_max( 4 * task.attempt, 'cpus' ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
    }
    withLabel: 'process_high' {
        cpus   = { check_max( 12 * task.attempt, 'cpus' ) }
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
    }
}

// 4. Profiles & Engine Settings
profiles {
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${baseDir}/singularity_cache"
        // Optional: bind additional paths for Singularity containers
        // Example: singularity.runOptions = '--bind /mnt/shared:/shared'
    }
}